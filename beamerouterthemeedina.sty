\mode<presentation>

\providecommand{\ed@numbering}{fraction}

\makeatletter

\usepackage{hyperref}

\defbeamertemplate*{frametitle}{edina}[1][]
{
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,sep=0pt,leftskip=0.55cm,rightskip=0.55cm,#1]{frametitle}
    \vskip0.32cm%
    {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
    \ifx\insertframesubtitle\@empty\else%
      {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
    \fi%
    \vskip0.12cm%
  \end{beamercolorbox}%
}

\setbeamertemplate{footline}{
  \ifbeamer@inappendix\else
    \ifnum\insertframenumber>1
      \def\ed@tmp{none}\ifx\ed@numbering\ed@tmp\else
        \def\ed@tmp{progressbar}\ifx\ed@numbering\ed@tmp
          \ifnum\insertmainframenumber>1
            \begingroup
            \dimen@=\paperwidth
            \multiply\dimen@ by \numexpr\insertframenumber-1\relax
            \divide\dimen@ by \numexpr\insertmainframenumber-1\relax
            \leavevmode
            \rlap{\color{edprimary!10}\rule{\paperwidth}{1.8pt}}%
            {\color{edprimary}\rule{\dimen@}{1.8pt}}%
            \endgroup
          \fi
        \else
          \begin{beamercolorbox}[wd=\paperwidth,ht=-2.5ex,dp=1.125ex,right]{page number in head/foot}
            \usebeamerfont{page number in head/foot}%
            \color{black!20}%
            \def\ed@tmp{number}\ifx\ed@numbering\ed@tmp
              \the\numexpr\insertframenumber-1\relax
            \else
              \ifnum\insertmainframenumber>1
                \the\numexpr\insertframenumber-1\relax/\the\numexpr\insertmainframenumber-1\relax
              \fi
            \fi
            \hspace{1em}
          \end{beamercolorbox}
        \fi
      \fi
    \fi
  \fi
}

\makeatother

\mode<all>
