\mode<presentation>

\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric,calc,shadows}
\RequirePackage{pgf}
\RequirePackage{graphicx}
\RequirePackage[T1]{fontenc}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}
\RequirePackage{enumitem}

% [sectionpage=<on|none>] — section divider pages. Default: on
%
% [agendastyle=<plain|pattern>] — agenda/section page background. Default: plain
%
% [numbering=<fraction|number|progressbar|none>] — slide numbering style. Default: fraction
%   fraction — i/N  (slide i of N, excluding title page)
%   number   — slide number only
%   progressbar — bottom progress bar showing i/N
%   none     — no slide numbering
\DeclareOptionBeamer{sectionpage}{\def\ed@sectionpage{#1}}
\DeclareOptionBeamer{agendastyle}{\def\ed@agendastyle{#1}}
\DeclareOptionBeamer{numbering}{\def\ed@numbering{#1}}
\ExecuteOptionsBeamer{sectionpage=off,agendastyle=pattern,numbering=progressbar}
\ProcessOptionsBeamer

\useinnertheme{edina}
\useoutertheme{edina}
\usecolortheme{edina}
\usefonttheme{edina}

\pdfstringdefDisableCommands{\def\translate#1{#1}}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[shadow=false]

\mode<all>
