% This file defines the color theme "edina" for the beamer presentation class.
% It sets various colors for different elements of the presentation, such as the title page, author, date, background, blocks, and itemize/enumerate items.
% The color scheme is based on the Northwestern University brand colors, but can be customized by redefining the color values.
% The file also includes a set of Northwestern University brand colors for reference.
% To use this color theme, include this file in your LaTeX document using the \usepackage command.
\mode<presentation>

% Settings
\setbeamercolor*{title page header}{fg=white}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor{background canvas}{bg=white}

% Create colors that will be used for the inner/outer themes. By default,
% use the nu colors below, but you can specify these colors in your own
% document if you want to change them. edprimary is the main color. 
% These colors are actually used in the inner/outer/color themes.
\definecolor{edprimary}{RGB}{078, 042, 132} % nupurple (and its variations below)
\definecolor{edprimary140}{RGB}{048, 016, 078}
\definecolor{edprimary130}{RGB}{056, 023, 090}
\definecolor{edprimary120}{RGB}{064, 031, 104}
\definecolor{edprimary110}{RGB}{072, 036, 118}
\definecolor{edprimary40}{RGB}{164, 149, 195}
\definecolor{edprimary30}{RGB}{182, 172, 209}
\definecolor{edprimary20}{RGB}{204, 196, 223}
\definecolor{edprimary10}{RGB}{228, 224, 238}

% Likewise, you can specify the color of alert and example text/boxes
\definecolor{edalerted}{RGB}{202, 124, 027} % nudarkorange
\definecolor{edexample}{RGB}{000, 134, 086} % nudarkgreen

% The ones below aren't actually used in the inner/outer/color themes.
% You can still redefine if you wish, but nothing will change
\definecolor{edprimary160}{RGB}{029, 002, 053}
\definecolor{edprimary150}{RGB}{038, 008, 065}
\definecolor{edprimary90}{RGB}{91, 59, 140}
\definecolor{edprimary80}{RGB}{104, 076, 150}
\definecolor{edprimary70}{RGB}{118, 093, 160}
\definecolor{edprimary60}{RGB}{131, 110, 170}
\definecolor{edprimary50}{RGB}{147, 128, 182}



% Northwestern Colors - Not referenced in the .sty files, but useful if using default color scheme
% For reference, see: http://www.northwestern.edu/brand/visual-identity/color/index.html
\definecolor{nupurple}{RGB}{078, 042, 132} % Default edprimary color
\definecolor{nupurple90}{RGB}{91, 59, 140}
\definecolor{nupurple80}{RGB}{104, 076, 150}
\definecolor{nupurple70}{RGB}{118, 093, 160}
\definecolor{nupurple60}{RGB}{131, 110, 170}
\definecolor{nupurple50}{RGB}{147, 128, 182}
\definecolor{nupurple40}{RGB}{164, 149, 195}
\definecolor{nupurple30}{RGB}{182, 172, 209}
\definecolor{nupurple20}{RGB}{204, 196, 223}
\definecolor{nupurple10}{RGB}{228, 224, 238}
\definecolor{nupurple160}{RGB}{029, 002, 053}
\definecolor{nupurple150}{RGB}{038, 008, 065}
\definecolor{nupurple140}{RGB}{048, 016, 078}
\definecolor{nupurple130}{RGB}{056, 023, 090}
\definecolor{nupurple120}{RGB}{064, 031, 104}
\definecolor{nupurple110}{RGB}{072, 036, 118}
\definecolor{nurichblack}{RGB}{0,0,0}
\definecolor{nubrightgreen}{RGB}{88,185,71}
\definecolor{nubrightteal}{RGB}{127, 206, 205}
\definecolor{nubrightblue}{RGB}{80, 145, 205}
\definecolor{nubrightyellow}{RGB}{237, 233, 59}
\definecolor{nubrightorange}{RGB}{255, 197, 32}
\definecolor{nubrightred}{RGB}{239, 085, 063}
\definecolor{nudarkgreen}{RGB}{000, 134, 086} % Default edexample color
\definecolor{nudarkteal}{RGB}{000, 127, 164}
\definecolor{nudarkblue}{RGB}{013, 045, 108}
\definecolor{nudarkyellow}{RGB}{217, 200, 038}
\definecolor{nudarkorange}{RGB}{202, 124, 027} % Default edalerted color
\definecolor{nudarkred}{RGB}{216, 088, 032}

% Enumerate item color
\setlist[enumerate]{label={\ifnum\@itemdepth=1\relax
  \color{edalerted}\else
  \color{edprimary}\fi\theenumi.}}

% Itemize item color (bullet)
\setlist[itemize]{label=\color{edprimary}$\bullet$}
%\setlist[itemize]{label=\color{edprimary}\textbullet}

% Change alerted text color to edalerted (default is nudarkorange)
\setbeamercolor{alerted text}{fg=edalerted}

% Turn off shading for block title when rounded=true (by default, rounded = false)
\makeatletter
\pgfdeclareverticalshading[lower.bg,upper.bg]{bmb@transition}{200cm}{%
  color(0pt)=(lower.bg); color(4pt)=(lower.bg); color(4pt)=(upper.bg)}

% Change block title background to edprimary and body bg to edprimary10
\setbeamercolor{block title}{fg=white,bg=edprimary}
\setbeamercolor{block body}{parent=normal text,fg=black,bg=edprimary10}

% Change the alertblock title background to alerted text color
\setbeamercolor{block title alerted}{fg=white,bg=edalerted}
\setbeamercolor{block body alerted}{fg=black,bg=edalerted!10}

% Change the exampleblock title background to greens
\setbeamercolor{block title example}{fg=white,bg=edexample}
\setbeamercolor{block body example}{fg=black,bg=edexample!10}

% Change cption text color to edprimary
\setbeamercolor{caption name}{fg=edprimary}

% Button styling. Tweak these defaults here if you want to restyle
% \beamerbutton, \beamergotobutton, and related button commands theme-wide.
\setbeamercolor{button}{fg=white,bg=edprimary}
\setbeamercolor{button border}{fg=edprimary}
