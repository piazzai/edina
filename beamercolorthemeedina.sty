\mode<presentation>

\setbeamercolor*{title page header}{fg=white}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor{background canvas}{bg=white}

% core colors
\definecolor{eduniversityred}{HTML}{D50032}
\definecolor{eduniversityblue}{HTML}{041E42}

% digital palette
\definecolor{edbrightblue}{HTML}{007288}
\definecolor{edbrightpink}{HTML}{D0006F}
\definecolor{edpurple}{HTML}{830065}
\definecolor{edburgundy}{HTML}{A50034}
\definecolor{eddarkgreen}{HTML}{154734}
\definecolor{edjade}{HTML}{487A7B}
\definecolor{edmutedblue}{HTML}{004F71}
\definecolor{edmutedbrown}{HTML}{6D4F47}
\definecolor{edsprucegrey}{HTML}{333F48}

\colorlet{edprimary}{eduniversityblue}
\colorlet{edprimary10}{edprimary!10}
\colorlet{edprimary20}{edprimary!20}
\colorlet{edprimary30}{edprimary!30}
\colorlet{edprimary40}{edprimary!40}
\colorlet{edprimary110}{edprimary!110}
\colorlet{edprimary120}{edprimary!120}
\colorlet{edprimary130}{edprimary!130}
\colorlet{edprimary140}{edprimary!140}

\colorlet{edalerted}{eduniversityred}
\colorlet{edexample}{eddarkgreen}

\setlist[enumerate]{label={\ifnum\@itemdepth=1\relax
        \color{edalerted}\else
        \color{edprimary}\fi\theenumi.}}

\setlist[itemize]{label=\color{edprimary}$\bullet$}

\setbeamercolor{alerted text}{fg=edalerted}

\makeatletter
\pgfdeclareverticalshading[lower.bg,upper.bg]{bmb@transition}{200cm}{%
  color(0pt)=(lower.bg); color(4pt)=(lower.bg); color(4pt)=(upper.bg)}

\setbeamercolor{block title}{fg=white,bg=edprimary}
\setbeamercolor{block body}{parent=normal text,fg=black,bg=edprimary10}

\setbeamercolor{block title alerted}{fg=white,bg=edalerted}
\setbeamercolor{block body alerted}{fg=black,bg=edalerted!10}

\setbeamercolor{block title example}{fg=white,bg=edexample}
\setbeamercolor{block body example}{fg=black,bg=edexample!10}

\setbeamercolor{caption name}{fg=edprimary}

\setbeamercolor{button}{fg=white,bg=edprimary}
\setbeamercolor{button border}{fg=edprimary}

\setbeamercolor{section in toc}{fg=edprimary}

\setbeamercolor{frametitle continuation}{fg=edprimary}

\setbeamercolor{frametitle}{fg=edprimary}

\mode
<all>
