% \renewcommand. All design commands accept a color argument — only
% \bgpatternfacet and \bgpatternfacetlight are hardcoded to edprimary.
%
% IMPORTANT: The color argument must be a simple named color (e.g. edprimary,
% nudarkblue). Compound xcolor expressions like "edprimary20!30" cannot be
% passed directly — they break when embedded in a further "!N" mix. Use
% \colorlet to pre-resolve compound expressions into a named color first:
%   \AtBeginDocument{\colorlet{mylight}{edprimary20!30}}
%   \renewcommand{\bgpatternlight}{\bgpatterntriangle{mylight}}
%
% Available designs:
%   Facet (NW exact):   \bgpatternfacet / \bgpatternfacetlight / \bgpatternblockfacet{color}
%   Random facet:       \bgpatternfacetrand{color}
%   Triangle mosaic:    \bgpatterntriangle{color}
%   Isometric triangles:\bgpatterntriangleiso{color}
%   Triangle mesh:      \bgpatterntrianglemesh{color}
%   Squares:            \bgpatternsquares{color}
%   Circles:            \bgpatterncircles{color}
%   Hex raised:         \bgpatternhexraise{color}
%   Hex random:         \bgpatternhexrand{color}
%   Network:            \bgpatternnetwork{color}
%   Quilt:              \bgpatternquilt{color}
%   Plain (solid):      \bgpatternplain{color}
% ==========================================================================

% Facet design — active
% \newcommand{\bgpattern}{\bgpatternfacet}
% \newcommand{\bgpatternblock}[1]{\bgpatternblockfacet{#1}}

% Other designs — uncomment one block to activate
% \newcommand{\bgpattern}{\bgpatterntriangle{edprimary}}
% \newcommand{\bgpatternblock}[1]{\bgpatterntriangle{#1}}

\newcommand{\bgpatternlogo}[1]{%
  \fill[#1!90!black] (current page.south west) rectangle (current page.north east);
  \coordinate (center) at ($(current page.north west)+(2,-1)$);
  \fill[#1,opacity=1] (center) circle [radius=0.8\paperwidth];
  \node[opacity=.1,rotate=-5] at (center) {\includegraphics[width=1.55\paperwidth]{logo/roundel.pdf}};
}

\newcommand{\bgpattern}{\bgpatternlogo{edprimary}}
\newcommand{\bgpatternblock}[1]{\bgpatternlogo{#1}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PATTERN CACHE
% Render \bgpattern once into saveboxes so complex patterns are not
% recomputed on every section or standout slide.
%   \ed@bgpatternbox   — full pattern (title page, standout frames)
%   \ed@bgsectionbox   — full pattern + white bottom-quarter band (section pages)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newsavebox{\ed@bgpatternbox}
% \newsavebox{\ed@bgsectionbox}
\newsavebox{\ed@pblockpatternbox}
\newsavebox{\ed@palertpatternbox}
\newsavebox{\ed@pexamplepatternbox}
\newif\ifed@pblockpatterncached
\newif\ifed@palertpatterncached
\newif\ifed@pexamplepatterncached
\AtBeginDocument{%
  \savebox{\ed@bgpatternbox}{%
    \begin{tikzpicture}
      \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
      \bgpattern
    \end{tikzpicture}%
  }%
  % \savebox{\ed@bgsectionbox}{%
  %   \begin{tikzpicture}
  %     \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
  %     \bgpatternblock{edprimary}
  %   \end{tikzpicture}%
  % }%
}

% Pattern block backgrounds are rendered lazily. Most decks never use pblock
% variants, so the expensive full-slide pattern boxes are populated only on
% first use of the matching built-in block color.
\newcommand{\ed@ensurepblockpattern}{%
  \ifed@pblockpatterncached\else
    \global\setbox\ed@pblockpatternbox=\hbox{%
      \begin{tikzpicture}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \bgpatternblock{edprimary}%
      \end{tikzpicture}%
    }%
    \global\wd\ed@pblockpatternbox=0pt
    \global\ht\ed@pblockpatternbox=0pt
    \global\dp\ed@pblockpatternbox=0pt
    \global\ed@pblockpatterncachedtrue
  \fi
}
\newcommand{\ed@ensurepalertpattern}{%
  \ifed@palertpatterncached\else
    \global\setbox\ed@palertpatternbox=\hbox{%
      \begin{tikzpicture}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \bgpatternblock{edalerted}%
      \end{tikzpicture}%
    }%
    \global\wd\ed@palertpatternbox=0pt
    \global\ht\ed@palertpatternbox=0pt
    \global\dp\ed@palertpatternbox=0pt
    \global\ed@palertpatterncachedtrue
  \fi
}
\newcommand{\ed@ensurepexamplepattern}{%
  \ifed@pexamplepatterncached\else
    \global\setbox\ed@pexamplepatternbox=\hbox{%
      \begin{tikzpicture}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \bgpatternblock{edexample}%
      \end{tikzpicture}%
    }%
    \global\wd\ed@pexamplepatternbox=0pt
    \global\ht\ed@pexamplepatternbox=0pt
    \global\dp\ed@pexamplepatternbox=0pt
    \global\ed@pexamplepatterncachedtrue
  \fi
}
\newcommand{\ed@ifdefaultpblockcolor}[3]{%
  \def\ed@tmpa{#1}%
  \def\ed@tmpb{edprimary}%
  \ifx\ed@tmpa\ed@tmpb
    #2%
  \else
    #3%
  \fi
}
\newcommand{\ed@patternblockunderlay}[1]{%
  \ed@ifdefaultpblockcolor{#1}{%
    \pgftext[left,bottom,at={\pgfpoint{0pt}{0pt}}]{\copy\ed@pblockpatternbox}%
  }{%
    \bgpatternblock{#1}%
  }%
}
\newcommand{\ed@ensuredefaultpblockpattern}[1]{%
  \ed@ifdefaultpblockcolor{#1}{%
    \ed@ensurepblockpattern
  }{}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Set the background template
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\setbeamertemplate{background}{
  \ifnum\insertframenumber=1
    \begin{tikzpicture}
      \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
      \node[anchor=south west,inner sep=0] at (0,0) {\usebox{\ed@bgpatternbox}};
      % Add the logo if \titlegraphic is not blank
      \ifx\inserttitlegraphic\@empty\relax
      \else
        \node[anchor=west,inner sep=0] at (0.05*\the\paperwidth,0.89*\the\paperheight) {\inserttitlegraphic};
      \fi
    \end{tikzpicture}%
  \fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Set the title page text positioning
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\defbeamertemplate*{title page}{edina}[1][]
{
  % Clear the headline/footline template
  \setbeamertemplate{headline}{}
  \setbeamertemplate{footline}{}
  \setbeamertemplate{navigation symbols}{}
  \vfill
  \vskip0.4\paperheight%
  \begin{beamercolorbox}[wd=0.75\paperwidth,leftskip=0cm,sep=8pt,#1]{title page header}
    \raggedright\usebeamerfont{title}\inserttitle\par%
  \end{beamercolorbox}%
  \vskip0.075\paperheight%
  \begin{beamercolorbox}[wd=0.75\paperwidth,leftskip=0cm,#1]{author}
    \raggedright\usebeamerfont{author}\insertauthor%
  \end{beamercolorbox}
  \vskip0.02\paperheight%
  \begin{beamercolorbox}[wd=0.75\paperwidth,leftskip=0cm,#1]{date}
    \raggedright\usebeamerfont{author}\insertdate%
  \end{beamercolorbox}
  \vfill
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Section divider pages and agenda-style table of contents
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\makeatletter

% The agenda-style TOC and section pages need a small amount of aux-backed state:
% 1. where the appendix begins, so appendix sections stay out of the agenda
% 2. which sections have subsections, plus the formatted subsection lines to show
%    inside the expanded section-page block
\AtBeginDocument{%
  \immediate\write\@auxout{\string\gdef\string\ed@appendixsectionthreshold{9999}}%
}

\let\ed@origappendix\appendix
\renewcommand{\appendix}{%
  \xdef\ed@appendixsectionthreshold{\number\value{section}}%
  \immediate\write\@auxout{%
    \string\gdef\string\ed@appendixsectionthreshold{\ed@appendixsectionthreshold}%
  }%
  \ed@origappendix%
}

% Mark that section #1 has at least one subsection.
\newcommand{\ed@marksectionhassubsections}[1]{%
  \expandafter\gdef\csname ed@sectionhaschildren@#1\endcsname{1}%
}

% Cache preformatted subsection lines for section #1 so the active section page can
% render one complete mblock without relying on nested TOC callbacks.
\newcommand{\ed@recordsubsection}[3]{%
  \expandafter\ifx\csname ed@subsectionsfor@#1\endcsname\relax
    \expandafter\gdef\csname ed@subsectionsfor@#1\endcsname{}%
  \fi
  \expandafter\g@addto@macro\csname ed@subsectionsfor@#1\endcsname{%
    {\usebeamerfont{normal text}\color{black!65}\scriptsize #1.#2\space #3\par}%
    \vspace{0.25em}%
  }%
}

\newcommand{\ed@ifsectionhassubsections}[3]{%
  \ifcsname ed@sectionhaschildren@#1\endcsname
    #2%
  \else
    #3%
  \fi
}

\newcommand{\ed@insertstoredsubsections}[1]{%
  \ifcsname ed@subsectionsfor@#1\endcsname
    \csname ed@subsectionsfor@#1\endcsname
  \fi
}

% Beamer calls \subsection while writing the .toc, so we piggyback there and persist
% the agenda metadata to the aux file for the next compile pass.
\let\ed@origbeamer@subsection\beamer@subsection
\def\beamer@subsection[#1]#2{%
  \ed@origbeamer@subsection[{#1}]{#2}%
  \immediate\write\@auxout{%
    \string\ed@marksectionhassubsections{\number\value{section}}%
  }%
  \immediate\write\@auxout{%
    \string\ed@recordsubsection{\number\value{section}}{\number\value{subsection}}{#2}%
  }%
}

\newif\ifed@agendasectionpage
\newlength{\ed@agendatitleinset}
\setlength{\ed@agendatitleinset}{9pt}

\newcommand{\ed@agendatitle}{Agenda}
\newcommand{\ed@agendasubsectionline}[3]{%
  {\usebeamerfont{normal text}\color{black!65}\scriptsize #1.#2\space #3\par}%
  \vspace{0.25em}%
}

\newcommand{\ed@agendacollapsed}[2]{%
  \begin{mlineblock}[colframe=#1,coltitle=#2]{\inserttocsectionnumber.\space\inserttocsection}%
  \end{mlineblock}%
}

\newcommand{\ed@agendaexpanded}[2]{%
  \begin{mblock}[colframe=#1,coltitle=#2,attach boxed title to top left={xshift=\dimexpr\ed@agendatitleinset-3pt\relax,yshift*=-\tcboxedtitleheight/2}]{\inserttocsectionnumber.\space\inserttocsection}%
    \ed@insertstoredsubsections{\number\inserttocsectionnumber}%
  \end{mblock}%
}

% #1 is the fallback rendering used on the main TOC page. On section pages we ignore
% Beamer's shaded/unshaded routing and instead compare against the live section counter
% so the current section reliably expands even with custom TOC filtering.
\newcommand{\ed@renderagendasection}[1]{%
  \ifnum\inserttocsectionnumber>\ed@appendixsectionthreshold\relax\else
    \ifed@agendasectionpage
      \ifnum\inserttocsectionnumber=\value{section}\relax
        \ed@ifsectionhassubsections{\number\value{section}}{%
          \ed@agendaexpanded{edprimary}{edprimary}%
        }{%
          \ed@agendacollapsed{edprimary}{edprimary}%
        }%
      \else
        \ed@agendacollapsed{white}{edprimary!20}%
      \fi
    \else
      #1%
    \fi
  \fi
}

\newcommand{\ed@agendalayout}[1]{%
  \ifed@agendapattern
    \begin{tikzpicture}[remember picture,overlay]
      \begin{scope}[shift={(current page.south west)}]
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        % This overlay is inserted as frame content, after the frametitle has
        % been typeset. Clip it to the right strip so it cannot cover "Agenda".
        \clip (0.6\paperwidth,0) rectangle (\paperwidth,\paperheight);
          \node[anchor=south west,inner sep=0] at (0,0) {\usebox{\ed@bgpatternbox}};
      \end{scope}
    \end{tikzpicture}%
  \fi
  \vspace{1em}%
  \noindent\begin{minipage}{0.6\textwidth}
    \begingroup
    \let\vfill\relax
    \ed@origtableofcontents[#1]%
    \endgroup
  \end{minipage}%
}

% Section pages (enabled only when sectionpage=on)
\def\ed@tmp{on}\ifx\ed@sectionpage\ed@tmp
  \AtBeginSection[]{%
    \ifbeamer@inappendix\else
      {%
        \setbeamertemplate{background}{}%
        \setbeamertemplate{headline}{}%
        \setbeamertemplate{footline}{}%
        \begin{frame}[plain]{\ed@agendatitle}
          \ed@agendasectionpagetrue
          \ed@agendalayout{currentsection,hideothersubsections}%
        \end{frame}
      }%
    \fi
  }%
\fi

\defbeamertemplate*{section in toc}{edina}{%
  \ed@renderagendasection{\ed@agendacollapsed{white}{edprimary}}%
}

\defbeamertemplate*{section in toc shaded}{edina}[1][20]{%
  \ed@renderagendasection{\ed@agendacollapsed{white}{edprimary!20}}%
}

\defbeamertemplate*{subsection in toc}{edina}{%
  \ifed@agendasectionpage\else
    \ifnum\inserttocsectionnumber>\ed@appendixsectionthreshold\relax\else
      \ed@agendasubsectionline
      {\inserttocsectionnumber}
      {\inserttocsubsectionnumber}
      {\inserttocsubsection}%
    \fi
  \fi
}

\defbeamertemplate*{subsection in toc shaded}{edina}[1][20]{%
  \usebeamertemplate{subsection in toc}%
}

\defbeamertemplate*{subsubsection in toc}{edina}{}
\defbeamertemplate*{subsubsection in toc shaded}{edina}[1][20]{}

\setbeamertemplate{section in toc}[edina]
\setbeamertemplate{section in toc shaded}[edina]
\setbeamertemplate{subsection in toc}[edina]
\setbeamertemplate{subsection in toc shaded}[edina]
\setbeamertemplate{subsubsection in toc}[edina]
\setbeamertemplate{subsubsection in toc shaded}[edina]

\let\ed@origtableofcontents\tableofcontents
\renewcommand{\tableofcontents}[1][]{%
  \frametitle{\ed@agendatitle}%
  \ed@agendasectionpagefalse
  \ed@agendalayout{hideallsubsections,#1}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Create special blocks for alerts, examples, and facets
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% If you want the facet design to come through faintly in the interior, replace the fill
% color of the overlay to \fill[white, fill opacity=0.8]
% Patterned block with an optional color argument.
\newtcolorbox{edpblockbox}[2][edprimary]{
  enhanced,
  underlay={
      \begin{tcbclipframe}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \ed@patternblockunderlay{#1}
      \end{tcbclipframe}
    },
  overlay={
      \begin{tcbclipinterior}
        \fill[#1!5] (frame.south west) rectangle (frame.north east);
      \end{tcbclipinterior}
    },
  title=#2
}

\NewDocumentEnvironment{pblock}{O{edprimary} m}
{%
  \ed@ensuredefaultpblockpattern{#1}%
  \begin{edpblockbox}[#1]{#2}%
    }
    {\end{edpblockbox}}

\newtcolorbox{edpalertblockbox}[1]{
  enhanced,
  underlay={
      \begin{tcbclipframe}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \pgftext[left,bottom,at={\pgfpoint{0pt}{0pt}}]{\copy\ed@palertpatternbox}%
      \end{tcbclipframe}
    },
  overlay={
      \begin{tcbclipinterior}
        \fill[edalerted!5] (frame.south west) rectangle (frame.north east);
      \end{tcbclipinterior}
    },
  title=#1
}

\NewDocumentEnvironment{palertblock}{m}
{%
  \ed@ensurepalertpattern
  \begin{edpalertblockbox}{#1}%
    }
    {\end{edpalertblockbox}}

\newtcolorbox{edpexampleblockbox}[1]{
  enhanced,
  underlay={
      \begin{tcbclipframe}
        \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
        \pgftext[left,bottom,at={\pgfpoint{0pt}{0pt}}]{\copy\ed@pexamplepatternbox}%
      \end{tcbclipframe}
    },
  overlay={
      \begin{tcbclipinterior}
        \fill[edexample!5] (frame.south west) rectangle (frame.north east);
      \end{tcbclipinterior}
    },
  title=#1
}

\NewDocumentEnvironment{pexampleblock}{m}
{%
  \ed@ensurepexamplepattern
  \begin{edpexampleblockbox}{#1}%
    }
    {\end{edpexampleblockbox}}

% Material-style outline block with a floating label-like title.
\newtcolorbox{mblock}[2][colframe=edprimary,coltitle=edprimary]{
  enhanced,
  colback=white,
  boxrule=0.7pt,
  arc=2.5pt,
  left=8pt,
  right=8pt,
  top=10pt,
  bottom=8pt,
  before skip=8pt,
  after skip=8pt,
  title={#2},
  fonttitle=\footnotesize\bfseries,
  attach boxed title to top left={xshift=10pt,yshift*=-\tcboxedtitleheight/2},
  boxed title style={
      frame hidden,
      boxrule=0pt,
      boxsep=0pt,
      sharp corners,
      top=0pt,
      bottom=0pt,
      left=3pt,
      right=3pt,
      colback=white
    },
  #1
}

\RenewDocumentEnvironment{block}{d<> m}
{%
  \IfNoValueF{#1}{\begin{actionenv}<#1>}%
      \begin{mblock}[colframe=edprimary,coltitle=edprimary]{#2}%
        }
        {%
      \end{mblock}%
      \IfNoValueF{#1}{\end{actionenv}}%
}

\RenewDocumentEnvironment{alertblock}{d<> m}
{%
  \IfNoValueF{#1}{\begin{actionenv}<#1>}%
      \begin{mblock}[colframe=edalerted,coltitle=edalerted]{#2}%
        }
        {%
      \end{mblock}%
      \IfNoValueF{#1}{\end{actionenv}}%
}

\RenewDocumentEnvironment{exampleblock}{d<> m}
{%
  \IfNoValueF{#1}{\begin{actionenv}<#1>}%
      \begin{mblock}[colframe=edexample,coltitle=edexample]{#2}%
        }
        {%
      \end{mblock}%
      \IfNoValueF{#1}{\end{actionenv}}%
}

\pgfkeys{
  /ed/mline/.is family,
  /ed/mline,
  colframe/.store in=\ed@mlinecolframe,
  coltitle/.store in=\ed@mlinecoltitle,
  colframe=edprimary,
  coltitle=edprimary
}

\NewDocumentEnvironment{mlineblock}{O{} m}
{%
  \pgfkeys{/ed/mline,colframe=edprimary,coltitle=edprimary,#1}%
  \par\medskip
  \noindent\makebox[\ed@agendatitleinset][l]{\color{\ed@mlinecolframe}\raisebox{0.45ex}{\rule{0.5em}{0.7pt}}}%
  {\color{\ed@mlinecoltitle}\footnotesize\bfseries #2\par}%
  \vspace{0.35em}%
}
{\par}

% Backward-compatibility alias: \tfacetbox was renamed to \pblock.
% Old code using \begin{tfacetbox}...\end{tfacetbox} will still work.
\NewDocumentEnvironment{tfacetbox}{O{edprimary} m}
{\begin{pblock}[#1]{#2}}
    {\end{pblock}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Standout Frame
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Create a standout frame for important points. It should be blank, with the body 
% text centered vertically and horizontally. There should be no title
\newcommand{\standout}[1]{
  {
        \setbeamertemplate{background}{%
          \usebox{\ed@bgpatternbox}%
        }
      \setbeamertemplate{footline}{}
      \begin{frame}
        \vfill
        \begin{beamercolorbox}[sep=8pt,center,shadow=false,rounded=false]{title}
          {\color{edprimary10}\usebeamerfont{section}#1\par}
        \end{beamercolorbox}
      \end{frame}
    }
}



