% This file defines the inner theme "edina" for the beamer class.
% It contains commands and templates for customizing the background, title page, section pages, and special blocks.
% The main pattern for the background is defined in the \bgpattern command, which is used in various templates and environments.
% The \bgpatternlight command creates a lighter version of the background pattern for section pages.
% The \bgpatternblock command creates a color-specific version of the background pattern for pblocks.
% The background template is set using the \setbeamertemplate{background} command, which includes the main pattern and optional logo.
% The title page template is defined using the \defbeamertemplate*{title page}{edina} command, which positions the title, author, and date.
% Section pages are generated using the \AtBeginSection[] command, which sets the background template and displays the section name.
% Special blocks for alerts, examples, and facets are defined using the \newtcolorbox command, which sets the background pattern and color.
% The \standout command creates a standout frame with a blank background and centered text.
\mode<presentation>

% Defaults for standalone usage (without beamerthemeedina.sty)
\providecommand{\ed@pattern}{facet}
\providecommand{\ed@agendastyle}{plain}
\providecommand{\ed@sectionpage}{none}
\providecommand{\ed@appendixsectionthreshold}{9999}
\newif\ifed@plainpattern
\def\ed@tmp{plain}\ifx\ed@pattern\ed@tmp
  \ed@plainpatterntrue
\else
  \ed@plainpatternfalse
\fi
\newif\ifed@agendapattern
\def\ed@tmp{pattern}\ifx\ed@agendastyle\ed@tmp
  \ed@agendapatterntrue
\else
  \ed@agendapatternfalse
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% BACKGROUND PATTERN DESIGNS
%
% All templates in this file use two commands:
%   \bgpattern       - full-color background (title page, section pages, standout frames)
%   \bgpatternblock  - color-parameterized background (tcolorbox blocks)
%
% Section pages use the full-color \bgpattern with a white rectangle over
% the bottom third, and the section name in edprimary in that white band.
%
% These are defined as wrappers at the bottom of this section ("Active
% Design"). To switch designs, update those two \newcommand lines here,
% or override them in your document preamble after \usetheme{edina}:
%   \renewcommand{\bgpattern}{...}
%   \renewcommand{\bgpatternblock}[1]{...}
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

